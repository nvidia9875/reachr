# Reachr — Gemini configuration.
# Without any of these set, Reachr uses a deterministic fallback (still works
# end-to-end; responses are hand-authored instead of model-generated).

# ── Option A: Vertex AI (recommended) ────────────────────────────────────────
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1
# (auth via `gcloud auth application-default login` or the Cloud Run service account)

# ── Option B: Gemini Developer API key ───────────────────────────────────────
# GEMINI_API_KEY=your-key

# Model (either mode):
GEMINI_MODEL=gemini-2.5-flash

# HTTP port (Cloud Run injects PORT):
PORT=8080
